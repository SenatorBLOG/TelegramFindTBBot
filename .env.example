# ────────────────────────────────────────────────
# Find the Travel Buddy — environment config
# Copy to `.env` and fill in real values
# ────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Mode: TEST or PROD
MODE=TEST

# Forum-enabled supergroup IDs (use /chatid inside the group to find)
TEST_GROUP_ID=-1001234567890
PROD_GROUP_ID=-1009876543210

# Your Telegram numeric user ID (admin who can run /release, /stats, /moderation)
ADMIN_USER_ID=123456789

# Profile moderation — require admin approval before profiles go public (default: false)
MODERATION=false

# Webhook — PROD mode only. Leave blank to use polling (works for local dev).
# WEBHOOK_URL=https://your-server.com
# WEBHOOK_PATH=/webhook
# WEBHOOK_PORT=8080

# SQLite database path (default: data/bot.db)
# DB_PATH=data/bot.db
